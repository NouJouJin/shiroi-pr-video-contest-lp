{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "redirects": [
    { "source": "/SHIROI.html", "destination": "/", "permanent": true },
    { "source": "/gallery.html", "destination": "/gallery", "permanent": true }
  ],
  "rewrites": [
    { "source": "/", "destination": "/SHIROI.html" },
    { "source": "/gallery", "destination": "/gallery.html" }
  ],
  "headers": [
    {
      "source": "/data/entries.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=60, s-maxage=60" }
      ]
    },
    {
      "source": "/(css|js)/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
